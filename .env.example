# ===========================================
# UFMI Employee Reporting System - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# PostgreSQL Database URL (required)
# Get this from your database provider (Neon, Supabase, Vercel Postgres, etc.)
# Format: postgresql://username:password@host:5432/database?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT Secret for authentication (required)
# Use a long random string (e.g., generate with: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key-change-this"

# Optional: Application URL (used for redirects, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
